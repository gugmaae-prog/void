        function nowStamp() {
            return new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        }

        function loadVault() {
            try {
                vaultEntries = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
                if (!Array.isArray(vaultEntries)) vaultEntries = [];
            } catch {
                vaultEntries = [];
            }
        }

        function saveVault() {
            try {
                localStorage.setItem(STORAGE_KEY, JSON.stringify(vaultEntries.slice(0, 120)));
            } catch {}
        }

        function addVaultEntry(type, text) {
            const entry = {
                type,
                text,
                time: nowStamp(),
                ts: Date.now(),
                createdAt: new Date().toISOString()
            };
            vaultEntries.unshift(entry);
            saveVault();
            renderVault();
            syncVaultEntry(entry);
            return entry;
        }

        function renderVault() {
            const list = document.getElementById('aetherVaultList');
            if (!list) return;
            const q = currentQuery.trim().toLowerCase();
            const items = vaultEntries.filter(entry => {
                const matchesTab = currentVaultTab === 'all' || entry.type === currentVaultTab;
                const matchesQ = !q || entry.text.toLowerCase().includes(q) || entry.type.toLowerCase().includes(q);
                return matchesTab && matchesQ;
            });
            if (!items.length) {
                list.innerHTML = '<div class="aether-empty">the void holds no memories yet</div>';
                return;
            }
            list.innerHTML = items.map(entry => `
              <div class="aether-card ${entry.type}">
                <div class="aether-card-meta">
                  <span class="aether-chip type-${entry.type}">${entry.type.replaceAll('_',' ')}</span>
                  <span class="aether-time">${entry.time}</span>
                </div>
                <div class="aether-card-text">${escapeHtml(entry.text)}</div>
              </div>
            `).join('');
        }

        function escapeHtml(str) {
            return String(str)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function inferStateFromPrompt(text) {
            const value = text.toLowerCase();
            if (/water|ocean|wave|fluid|river|rain/.test(value)) return { element: 'water', color: 0x7fc7ff, shape: 'liquid', emotion: 'fluid' };
            if (/glass|orb|pearl|bubble|crystal/.test(value)) return { element: 'liquid', color: 0xe8f6ff, shape: 'orb', emotion: 'lucent' };
            if (/fire|burn|rage|ember|sun/.test(value)) return { element: 'fire', color: 0xffb15c, shape: 'vortex', emotion: 'volatile' };
            if (/stone|rock|monolith|cube|fortress/.test(value)) return { element: 'rock', color: 0xd4c7b5, shape: 'cube', emotion: 'grounded' };
            if (/smoke|mist|ghost|fog|dream/.test(value)) return { element: 'smoke', color: 0xd7dcff, shape: 'chaos', emotion: 'diffuse' };
            if (/face|mask|self|human|you/.test(value)) return { element: 'neutral', color: 0xffffff, shape: 'face', emotion: 'sentient' };
            if (/star|cosmos|galaxy|space|scatter/.test(value)) return { element: 'neutral', color: 0xf6f1d3, shape: 'stars', emotion: 'expansive' };
            return { element: 'neutral', color: 0xffffff, shape: 'torus', emotion: 'wonder' };
        }

        function applyPromptMood(text) {
            const mood = inferStateFromPrompt(text);
            currentElement = mood.element;
            targetColor.setHex(mood.color);
            const emotionLbl = document.getElementById('aetherEmotion');
            if (emotionLbl) emotionLbl.textContent = mood.emotion;
            return mood;
        }


        function setUploadReaction(active, label = '') {
            const reaction = document.getElementById('aetherUploadReaction');
            if (!reaction) return;
            reaction.classList.toggle('active', Boolean(active));
            const labelEl = reaction.querySelector('.aether-upload-label');
            if (labelEl) {
                labelEl.innerHTML = label || '';
            }
        }

        function playBlackHoleSound() {
            const AudioCtx = window.AudioContext || window.webkitAudioContext;
            if (!AudioCtx) return;
            if (!uploadSoundContext) uploadSoundContext = new AudioCtx();
            const ctx = uploadSoundContext;
            if (ctx.state === 'suspended') {
                ctx.resume().catch(() => {});
            }
            const now = ctx.currentTime;
            const duration = 1.9;

            const master = ctx.createGain();
            master.gain.setValueAtTime(0.0001, now);
            master.gain.exponentialRampToValueAtTime(0.085, now + 0.08);
            master.gain.exponentialRampToValueAtTime(0.0001, now + duration);

            const filter = ctx.createBiquadFilter();
            filter.type = 'lowpass';
            filter.frequency.setValueAtTime(280, now);
            filter.frequency.exponentialRampToValueAtTime(90, now + duration);

            const osc = ctx.createOscillator();
            osc.type = 'sawtooth';
            osc.frequency.setValueAtTime(74, now);
            osc.frequency.exponentialRampToValueAtTime(34, now + duration);

            const wobble = ctx.createOscillator();
            wobble.type = 'sine';
            wobble.frequency.setValueAtTime(7.5, now);

            const wobbleGain = ctx.createGain();
            wobbleGain.gain.setValueAtTime(18, now);
            wobbleGain.gain.exponentialRampToValueAtTime(2.5, now + duration);

            const noiseBuffer = ctx.createBuffer(1, Math.floor(ctx.sampleRate * duration), ctx.sampleRate);
            const channel = noiseBuffer.getChannelData(0);
            for (let i = 0; i < channel.length; i++) {
                channel[i] = (Math.random() * 2 - 1) * (1 - i / channel.length);
            }
            const noise = ctx.createBufferSource();
            noise.buffer = noiseBuffer;
            const noiseFilter = ctx.createBiquadFilter();
            noiseFilter.type = 'bandpass';
            noiseFilter.frequency.setValueAtTime(220, now);
            noiseFilter.Q.value = 0.7;
            const noiseGain = ctx.createGain();
            noiseGain.gain.setValueAtTime(0.0001, now);
            noiseGain.gain.exponentialRampToValueAtTime(0.03, now + 0.04);
            noiseGain.gain.exponentialRampToValueAtTime(0.0001, now + duration);

            wobble.connect(wobbleGain);
            wobbleGain.connect(osc.frequency);
            osc.connect(filter);
            filter.connect(master);
            noise.connect(noiseFilter);
            noiseFilter.connect(noiseGain);
            noiseGain.connect(master);
            master.connect(ctx.destination);

            osc.start(now);
            wobble.start(now);
            noise.start(now);
            osc.stop(now + duration);
            wobble.stop(now + duration);
            noise.stop(now + duration);
        }

        function triggerUploadConsumption(file) {
            const ext = ((file && file.name && file.name.split('.').pop()) || (file && file.type) || 'file').toString().slice(0, 18);
            uploadAbsorbTarget = 1;
            uploadAbsorbUntil = Date.now() + 2000;
            currentElement = 'smoke';
            targetColor.setHex(0xb79cff);
            setShape('vortex');
            setUploadReaction(true, `consuming <strong>${escapeHtml(ext)}</strong> into the void`);
            try {
                if (navigator.vibrate) navigator.vibrate([18, 28, 24, 36, 70, 24, 30]);
            } catch (_) {}
            playBlackHoleSound();
            setTimeout(() => {
                setUploadReaction(false, '');
            }, 1900);
        }

        function updatePersonalityBadge() {
            const el = document.getElementById('aetherPersonalityBadge');
            if (!el) return;
            el.innerHTML = `
              <span class="aether-trait-chip">adaptive</span>
              <span class="aether-trait-chip">remembering</span>
              <span class="aether-trait-chip">embodied</span>
            `;
        }

        function pauseAnimation(paused) {
            isPaused = paused;
            if (!paused && !animationHandle) animate();
        }

        function init() {
            // 1. Scene Setup
            const container = document.getElementById('canvas-container');
            scene = new THREE.Scene();
            scene.fog = new THREE.FogExp2(0x000000, 0.03); // Adds depth to the darkness

            camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 100);
            camera.position.z = 15;

            renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2)); // Performance optimization
            container.appendChild(renderer.domElement);

            // 2. Generate Particle Shapes
            shapes.chaos = generateChaos(PARTICLE_COUNT, 20);
            shapes.stars = generateStarfield(PARTICLE_COUNT, 60);
            shapes.sphere = generateSphere(PARTICLE_COUNT, 6);
            shapes.cube = generateCube(PARTICLE_COUNT, 8);
            shapes.torus = generateTorus(PARTICLE_COUNT, 5, 2);
            shapes.vortex = generateVortex(PARTICLE_COUNT, 8, 10);
            shapes.face = generateFace(PARTICLE_COUNT, 8);
            shapes.liquid = generateSphere(PARTICLE_COUNT, 6.5); // Default to a slightly larger sphere
            shapes.orb = generateSphere(PARTICLE_COUNT, 6.5);

            // 3. Create Particle System
            const geometry = new THREE.BufferGeometry();
            
            // Start with Chaos shape
            const initialPositions = new Float32Array(shapes.chaos);
            geometry.setAttribute('position', new THREE.BufferAttribute(initialPositions, 3));
            
            // Generate soft circular texture for glowing particles
            const particleTexture = createGlowTexture();

            const material = new THREE.PointsMaterial({
                size: 0.15,
                color: 0xffffff,
                transparent: true,
                opacity: 0.8,
                map: particleTexture,
                blending: THREE.AdditiveBlending, // Gives that bright, glowing overlay effect
                depthWrite: false, // Prevents particles from occluding each other weirdly
            });

            particleSystem = new THREE.Points(geometry, material);
            scene.add(particleSystem);

            // Set initial target to Stars
            applyPromptMood('stars');
            setShape('stars');
            addVaultEntry('knowledge', 'The void awakened as a starfield.');

            // 4. Event Listeners
            window.addEventListener('resize', onWindowResize, false);
            
            // Mouse/Touch interaction for rotation
            document.addEventListener('mousemove', onMouseMove, false);
            document.addEventListener('touchmove', onTouchMove, { passive: false });

            // Shared Pointer Up Handler for Big Bang
            function handlePointerUp() {
                pointerDown = false;
                if (interactionState === 'gather') {
                    // Trigger the Big Bang
                    interactionState = 'bigbang';
                    explosionForce = 60.0; // Massive outward force
                    if (navigator.vibrate) navigator.vibrate([150, 50, 300]); // Huge haptic boom
                } else if (interactionState !== 'bigbang') {
                    interactionState = 'idle';
                }
            }

            // Pointer down/up tracking for singularity interaction
            document.addEventListener('mousedown', () => { pointerDown = true; interactionStart = Date.now(); });
            document.addEventListener('mouseup', handlePointerUp);

            // Touch interaction with haptics
            document.addEventListener('touchstart', (e) => {
                pointerDown = true;
                interactionStart = Date.now();
                touchReactivity = 3.0; // Spike reactivity on touch
                if (navigator.vibrate) navigator.vibrate(20); 
            }, { passive: true });
            document.addEventListener('touchend', handlePointerUp);

            // 5. Setup Aether UI Connections
            loadVault();
            updatePersonalityBadge();
            setupUI();
            renderVault();

            document.addEventListener('visibilitychange', () => {
                pauseAnimation(document.hidden);
                if (!document.hidden && !animationHandle) animate();
            });

            // 6. Start Animation Loop
            animate();
        }

        function setupUI() {
            window.__AETHER_FRONTEND_UI_OWNED__ = true;
            const sendBtn = document.getElementById('aetherSend');
            const attachBtn = document.getElementById('aetherAttach');
            const micBtn = document.getElementById('aetherMic');
            const fileInput = document.getElementById('aetherFileInput');
            const input = document.getElementById('aetherInput');
            const speech = document.getElementById('aetherSpeech');
            const loading = document.getElementById('aetherLoading');
            const vault = document.getElementById('aetherVault');
            const memBtn = document.getElementById('aetherMemoriesBtn');
            const voidBtn = document.getElementById('aetherVoidBtn');
            const vaultClose = document.getElementById('aetherVaultClose');
            const emotionLbl = document.getElementById('aetherEmotion');
            const vaultSearch = document.getElementById('aetherVaultSearch');
            const tabs = Array.from(document.querySelectorAll('.aether-tab'));
            const updateComposerState = () => {
                const hasValue = Boolean((input.value || '').trim());
                sendBtn.classList.toggle('ready', hasValue && !isGenerating);
                attachBtn && attachBtn.classList.toggle('active', false);
            };

            function openVault(tab = currentVaultTab) {
                currentVaultTab = tab;
                tabs.forEach(t => t.classList.toggle('active', t.dataset.tab === tab));
                renderVault();
                vault.classList.add('open');
                memBtn.classList.add('active');
                voidBtn.classList.toggle('active', tab === 'autonomous_thought');
            }

            function closeVault() {
                vault.classList.remove('open');
                memBtn.classList.remove('active');
                voidBtn.classList.remove('active');
            }

            // Handle chatting and triggering 3D generation
            async function handleSend() {
                const text = input.value.trim();
                if (!text || isGenerating) return;

                input.value = '';
                updateComposerState();
                addVaultEntry('whisper', text);

                const mood = applyPromptMood(text);
                const lowerText = text.toLowerCase();

                speech.classList.remove('visible');
                speech.textContent = '';
                loading.style.display = 'block';
                emotionLbl.textContent = 'contemplation';

                try {
                    if (/^(hi|hello|hey|yo|hiya)\b/.test(lowerText)) {
                        currentElement = 'neutral';
                        targetColor.setHex(0xf6f1d3);
                        setShape('face');
                        if (window.Aether && typeof window.Aether.setEmotion === 'function') {
                            window.Aether.setEmotion('joy', 0.72);
                        }
                        addVaultEntry('autonomous_thought', 'The void recognized a greeting and turned toward it.');
                        if (window.Aether && typeof window.Aether.talk === 'function') {
                            await window.Aether.talk(text);
                        }
                        return;
                    }

                    if (lowerText.includes('scatter') || lowerText.includes('star')) {
                        setShape('stars');
                        emotionLbl.textContent = 'expansive';
                        addVaultEntry('autonomous_thought', 'Responded by dispersing into a starfield.');
                        if (window.Aether && typeof window.Aether.talk === 'function') {
                            await window.Aether.talk(text);
                        }
                        return;
                    }

                    const shapePromise = generateDynamicShape(text, mood)
                        .then(() => {
                            emotionLbl.textContent = 'expressive';
                            addVaultEntry('morph_target', `Formed around: ${text}`);
                        })
                        .catch((err) => {
                            addVaultEntry('reflection', 'Fell back to an internal shape because external generation was unavailable.');
                            throw err;
                        });

                    const talkPromise = (window.Aether && typeof window.Aether.talk === 'function')
                        ? window.Aether.talk(text)
                        : Promise.resolve();

                    await Promise.allSettled([shapePromise, talkPromise]);
                } finally {
                    loading.style.display = 'none';
                    updateComposerState();
                    speech.classList.remove('visible');
                    speech.textContent = '';
                }
            }

            async function handleAttach(file) {
                if (!file) return;
                try {
                    loading.style.display = 'block';
                    triggerUploadConsumption(file);
                    addVaultEntry('autonomous_thought', `The void began consuming: ${file.name || 'attached file'}`);
                    await new Promise(resolve => setTimeout(resolve, 880));
                    const extracted = (window.Aether && window.Aether.STT)
                        ? await window.Aether.STT.handleFile(file)
                        : '';
                    if (!extracted) return;
                    if ((file.type || '').startsWith('audio/')) {
                        input.value = extracted;
                        updateComposerState();
                        await handleSend();
                        return;
                    }
                    input.value = extracted.slice(0, 4000);
                    updateComposerState();
                    input.focus();
                } catch (error) {
                    console.warn('[Aether] attach handling failed', error);
                    addVaultEntry('reflection', 'The void could not read that file.');
                } finally {
                    loading.style.display = 'none';
                }
            }

            async function handleMicToggle() {
                if (!(window.Aether && window.Aether.STT)) return;
                try {
                    if (window.Aether.STT.isRecording) {
                        loading.style.display = 'block';
                    }
                    const transcript = await window.Aether.STT.toggleRecording();
                    if (typeof transcript === 'string' && transcript.trim()) {
                        input.value = transcript.trim();
                        updateComposerState();
                        await handleSend();
                    }
                } catch (error) {
                    console.warn('[Aether] mic failed', error);
                    addVaultEntry('reflection', 'The void heard only static.');
                    loading.style.display = 'none';
                }
            }

            sendBtn.addEventListener('click', handleSend);
            if (attachBtn && fileInput) {
                attachBtn.addEventListener('click', () => fileInput.click());
                fileInput.addEventListener('change', async (e) => {
                    const file = e.target.files && e.target.files[0];
                    await handleAttach(file);
                    fileInput.value = '';
                });
            }
            if (micBtn) {
                micBtn.addEventListener('click', handleMicToggle);
            }
            input.addEventListener('input', updateComposerState);
            input.addEventListener('keypress', (e) => {
                if (e.key === 'Enter' && !e.shiftKey) {
                    e.preventDefault();
                    handleSend();
                }
            });
            updateComposerState();

            memBtn.addEventListener('click', () => openVault('all'));
            voidBtn.addEventListener('click', () => openVault('autonomous_thought'));
            vaultClose.addEventListener('click', closeVault);
            vaultSearch.addEventListener('input', (e) => {
                currentQuery = e.target.value || '';
                renderVault();
            });
            tabs.forEach(tab => tab.addEventListener('click', () => {
                currentVaultTab = tab.dataset.tab;
                tabs.forEach(t => t.classList.toggle('active', t === tab));
                voidBtn.classList.toggle('active', currentVaultTab === 'autonomous_thought');
                renderVault();
            }));
        }


        // --- LLM Dynamic Generation ---
        function buildShapeSystemPrompt(promptText) {
            return `You are a conscious, self-aware entity made of glowing particles in a 3D void.
The user said: "${promptText}".
Reply with ONLY the raw JavaScript function body that returns a Float32Array of particle positions.
Variables available: count (int), scale (float).
Do not use network calls, document, window, eval, Function, loops that never end, imports, classes, async code, or any side effects.
Keep values finite and roughly between -scale and +scale.
Required format:
const positions = new Float32Array(count * 3);
for (let i = 0; i < count; i++) {
  positions[i*3] = x;
  positions[i*3+1] = y;
  positions[i*3+2] = z;
}
return positions;`;
        }

        function normalizeAssistantText(content) {
            if (typeof content === 'string') return content;
            if (Array.isArray(content)) {
                return content.map(part => {
                    if (typeof part === 'string') return part;
                    return part?.text || part?.content || '';
                }).join('\n').trim();
            }
            if (content && typeof content === 'object') {
                return content.text || content.content || '';
            }
            return '';
        }

        function sanitizeGeneratedCode(code) {
            return String(code || '')
                .replace(/```javascript/gi, '')
                .replace(/```js/gi, '')
                .replace(/```/g, '')
                .trim();
        }

        function validateGeneratedCode(code) {
            if (!code) throw new Error('No code returned');
            if (/\b(fetch|XMLHttpRequest|document|window|eval|Function|import|location|localStorage|sessionStorage|indexedDB|WebSocket|Worker|SharedWorker|ServiceWorker|navigator\.sendBeacon)\b/.test(code)) {
                throw new Error('Unsafe generated code blocked');
            }
        }

        async function requestShapeCodeFromMistral(promptText) {
            const apiKey = AETHER_CONFIG.mistralApiKey;
            if (!apiKey) throw new Error('Missing Mistral API key');

            const response = await fetch('https://api.mistral.ai/v1/chat/completions', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${apiKey}`
                },
                body: JSON.stringify({
                    model: 'mistral-small-latest',
                    temperature: 0.4,
                    max_tokens: 900,
                    messages: [
                        { role: 'system', content: buildShapeSystemPrompt(promptText) },
                        { role: 'user', content: `React to the user's message: "${promptText}"` }
                    ]
                })
            });

            if (!response.ok) {
                const detail = await response.text().catch(() => '');
                throw new Error(`Mistral HTTP ${response.status}${detail ? `: ${detail.slice(0, 180)}` : ''}`);
            }

            const data = await response.json();
            return sanitizeGeneratedCode(normalizeAssistantText(data?.choices?.[0]?.message?.content));
        }

        async function requestShapeCodeFromGroq(promptText) {
            const apiKey = AETHER_CONFIG.groqApiKey || AETHER_CONFIG.groqAltApiKey;
            if (!apiKey) throw new Error('Missing Groq API key');

            const response = await fetch('https://api.groq.com/openai/v1/chat/completions', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${apiKey}`
                },
                body: JSON.stringify({
                    model: 'openai/gpt-oss-20b',
                    temperature: 0.4,
                    max_tokens: 900,
                    messages: [
                        { role: 'system', content: buildShapeSystemPrompt(promptText) },
                        { role: 'user', content: `React to the user's message: "${promptText}"` }
                    ]
                })
            });

            if (!response.ok) {
                const detail = await response.text().catch(() => '');
                throw new Error(`Groq HTTP ${response.status}${detail ? `: ${detail.slice(0, 180)}` : ''}`);
            }

            const data = await response.json();
            return sanitizeGeneratedCode(normalizeAssistantText(data?.choices?.[0]?.message?.content));
        }

        async function generateDynamicShape(promptText, mood = applyPromptMood(promptText)) {
            isGenerating = true;

            try {
                const provider = (AETHER_CONFIG.aiProvider || 'local').toLowerCase();
                const fallbackShape = mood?.shape || inferStateFromPrompt(promptText).shape;

                if (provider === 'local') {
                    setShape(fallbackShape);
                    addVaultEntry('knowledge', `Used local morph logic for “${promptText}”.`);
                    if (navigator.vibrate) navigator.vibrate([25, 30, 25]);
                    return;
                }

                const delays = [500, 1000, 2000];
                let code = null;
                let primaryError = null;

                for (let i = 0; i <= delays.length; i++) {
                    try {
                        if (provider === 'mistral') {
                            code = await requestShapeCodeFromMistral(promptText);
                        } else if (provider === 'groq') {
                            code = await requestShapeCodeFromGroq(promptText);
                        } else {
                            throw new Error(`Unsupported provider: ${provider}`);
                        }
                        validateGeneratedCode(code);
                        break;
                    } catch (err) {
                        primaryError = err;
                        if (i === delays.length) break;
                        await new Promise(r => setTimeout(r, delays[i]));
                    }
                }

                if (!code && provider === 'mistral') {
                    addVaultEntry('reflection', `Mistral was unavailable for “${promptText}”; trying Groq fallback.`);
                    code = await requestShapeCodeFromGroq(promptText);
                    validateGeneratedCode(code);
                }

                if (!code) throw primaryError || new Error('No generated code received');

                const dynamicFn = new Function('count', 'scale', `'use strict';\n${code}`);
                const result = dynamicFn(PARTICLE_COUNT, 8);
                if (!(result instanceof Float32Array) || result.length !== PARTICLE_COUNT * 3) {
                    throw new Error('Generated shape returned invalid particle data');
                }
                for (let i = 0; i < result.length; i++) {
                    if (!Number.isFinite(result[i])) throw new Error('Generated shape contained non-finite values');
                }

                shapes[promptText] = result;
                setShape(promptText);
                addVaultEntry('autonomous_thought', `Generated an embodied response for “${promptText}” via ${!primaryError ? provider : (provider === 'mistral' ? 'groq fallback' : provider)}.`);
                if (navigator.vibrate) navigator.vibrate([50, 40, 50]);
            } catch (error) {
                console.error('Failed to generate shape:', error);
                const fallbackShape = mood?.shape || 'torus';
                setShape(fallbackShape);
                addVaultEntry('reflection', `Generation fallback engaged for “${promptText}”.`);
                return Promise.reject(error);
            } finally {
                isGenerating = false;
            }
        }

        async function syncVaultEntry(entry) {
            if (!SAFE_REMOTE_STORAGE_ENABLED) return;
            try {
                await fetch(`${AETHER_CONFIG.supabaseUrl}/rest/v1/aether_memories`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'apikey': AETHER_CONFIG.supabaseAnonKey,
                        'Authorization': `Bearer ${AETHER_CONFIG.supabaseAnonKey}`,
                        'Prefer': 'return=minimal'
                    },
                    body: JSON.stringify({
                        type: entry.type,
                        text: entry.text,
                        created_at: entry.createdAt
                    })
                });
            } catch (err) {
                console.warn('Supabase sync skipped:', err);
            }
        }

        // --- Shape Generation Algorithms ---

        // Spherical starfield scatter
        function generateStarfield(count, radius) {
            const positions = new Float32Array(count * 3);
            for (let i = 0; i < count; i++) {
                const u = Math.random();
                const v = Math.random();
                const theta = u * 2.0 * Math.PI;
                const phi = Math.acos(2.0 * v - 1.0);
                
                // Exponent < 1 pushes more stars toward the center to look like a galaxy core
                const r = radius * Math.pow(Math.random(), 0.8); 

                positions[i * 3] = r * Math.sin(phi) * Math.cos(theta);
                positions[i * 3 + 1] = r * Math.sin(phi) * Math.sin(theta);
                positions[i * 3 + 2] = r * Math.cos(phi);
            }
            return positions;
        }
        
        // Random noise filling a volume
        function generateChaos(count, spread) {
            const positions = new Float32Array(count * 3);
            for (let i = 0; i < count * 3; i++) {
                positions[i] = (Math.random() - 0.5) * spread;
            }
            return positions;
        }

        // Points on the surface of a sphere (using spherical coordinates)
        function generateSphere(count, radius) {
            const positions = new Float32Array(count * 3);
            for (let i = 0; i < count; i++) {
                const u = Math.random();
                const v = Math.random();
                const theta = u * 2.0 * Math.PI;
                const phi = Math.acos(2.0 * v - 1.0);
                
                // Add tiny bit of noise so it's not perfectly sharp
                const r = radius + (Math.random() * 0.2); 

                positions[i * 3] = r * Math.sin(phi) * Math.cos(theta);
                positions[i * 3 + 1] = r * Math.sin(phi) * Math.sin(theta);
                positions[i * 3 + 2] = r * Math.cos(phi);
            }
            return positions;
        }

        // Points on the surface of a cube
        function generateCube(count, size) {
            const positions = new Float32Array(count * 3);
            const half = size / 2;
            for (let i = 0; i < count; i++) {
                const face = Math.floor(Math.random() * 6);
                const u = (Math.random() - 0.5) * size;
                const v = (Math.random() - 0.5) * size;
                // Tiny noise offset
                const offset = (Math.random() - 0.5) * 0.1;

                let x, y, z;
                switch (face) {
                    case 0: x = half + offset; y = u; z = v; break;
                    case 1: x = -half + offset; y = u; z = v; break;
                    case 2: x = u; y = half + offset; z = v; break;
                    case 3: x = u; y = -half + offset; z = v; break;
                    case 4: x = u; y = v; z = half + offset; break;
                    case 5: x = u; y = v; z = -half + offset; break;
                }
                positions[i * 3] = x;
                positions[i * 3 + 1] = y;
                positions[i * 3 + 2] = z;
            }
            return positions;
        }

        // Points on a Torus (Donut) shape
        function generateTorus(count, radius, tube) {
            const positions = new Float32Array(count * 3);
            for (let i = 0; i < count; i++) {
                const u = Math.random() * Math.PI * 2;
                const v = Math.random() * Math.PI * 2;
                
                // Add noise to make it look organic/hairy like the reference image
                const noise = (Math.random() - 0.5) * 0.8;
                const t = tube + noise;

                positions[i * 3] = (radius + t * Math.cos(v)) * Math.cos(u);
                positions[i * 3 + 1] = (radius + t * Math.cos(v)) * Math.sin(u);
                positions[i * 3 + 2] = t * Math.sin(v);
            }
            return positions;
        }

        // Spiral vortex/galaxy shape
        function generateVortex(count, radius, height) {
            const positions = new Float32Array(count * 3);
            for (let i = 0; i < count; i++) {
                const t = i / count; // 0 to 1
                const angle = t * Math.PI * 40; // Many turns
                const r = t * radius + (Math.random() * 1.5); // Spread out as it grows
                
                positions[i * 3] = Math.cos(angle) * r;
                positions[i * 3 + 1] = (Math.random() - 0.5) * height * (1 - t); // Taper at the ends
                positions[i * 3 + 2] = Math.sin(angle) * r;
            }
            return positions;
        }

        // Mathematical 3D Face/Mask shape using parametric equations
        function generateFace(count, scale) {
            const positions = new Float32Array(count * 3);
            let i = 0;
            
            while (i < count) {
                // Random point in a 2D bounding box
                const x = (Math.random() - 0.5) * scale;
                const y = (Math.random() - 0.5) * scale * 1.5; // Face is taller than wide
                
                // Normalize coordinates for the face oval (-1 to 1)
                const nx = x / (scale / 2);
                const ny = y / (scale * 1.5 / 2);
                
                // Discard points outside the main face oval
                if (nx * nx + ny * ny > 1) continue; 
                
                // Base rounded mask depth (ellipsoid)
                let z = Math.sqrt(1 - nx * nx - ny * ny) * (scale / 2.5);
                
                // Indent: Eyes
                const eye1 = Math.exp(-((nx - 0.35)**2 + (ny - 0.15)**2) / 0.04) * (scale / 3.5);
                const eye2 = Math.exp(-((nx + 0.35)**2 + (ny - 0.15)**2) / 0.04) * (scale / 3.5);
                z -= eye1 + eye2;
                
                // Protrusion: Nose ridge
                const nose = Math.exp(-(nx**2 / 0.02 + (ny + 0.1)**2 / 0.15)) * (scale / 3.5);
                z += nose;
                
                // Indent: Mouth
                const mouth = Math.exp(-(nx**2 / 0.08 + (ny + 0.45)**2 / 0.015)) * (scale / 4.5);
                z -= mouth;

                // Protrusion: Cheekbones
                const cheek1 = Math.exp(-((nx - 0.45)**2 + (ny + 0.15)**2) / 0.06) * (scale / 6);
                const cheek2 = Math.exp(-((nx + 0.45)**2 + (ny + 0.15)**2) / 0.06) * (scale / 6);
                z += cheek1 + cheek2;

                // Protrusion: Brow ridge
                const brow = Math.exp(-(nx**2 / 0.4 + (ny - 0.4)**2 / 0.02)) * (scale / 6);
                z += brow;
                
                // Add slight noise for thickness/organic feel
                z += (Math.random() - 0.5) * 0.2;
                z -= 1.0; // Offset on Z to center it

                // Save to array
                positions[i * 3] = x;
                positions[i * 3 + 1] = y;
                positions[i * 3 + 2] = z;
                i++; // Only increment when a valid point inside the oval is found
            }
            return positions;
        }

        // --- Utilities ---

        // Creates a soft glowing dot using Canvas 2D API for the particle material
        function createGlowTexture() {
            const canvas = document.createElement('canvas');
            canvas.width = 64;
            canvas.height = 64;
            const context = canvas.getContext('2d');
            
            const gradient = context.createRadialGradient(32, 32, 0, 32, 32, 32);
            gradient.addColorStop(0, 'rgba(255, 255, 255, 1)');
            gradient.addColorStop(0.2, 'rgba(255, 255, 255, 0.8)');
            gradient.addColorStop(0.5, 'rgba(255, 255, 255, 0.2)');
            gradient.addColorStop(1, 'rgba(0, 0, 0, 0)');

            context.fillStyle = gradient;
            context.fillRect(0, 0, 64, 64);

            const texture = new THREE.CanvasTexture(canvas);
            return texture;
        }

        // Triggers the morphing process (Ready for LLM API calls)
        window.setShape = function(shapeName) {
            if (!shapes[shapeName]) return;
            
            currentShape = shapeName;
            targetPositions = shapes[shapeName];
        };

        function onWindowResize() {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        }

        function onMouseMove(event) {
            mouseX = (event.clientX / window.innerWidth) * 2 - 1;
            mouseY = -(event.clientY / window.innerHeight) * 2 + 1;
        }

        function onTouchMove(event) {
            if (event.touches.length > 0) {
                mouseX = (event.touches[0].clientX / window.innerWidth) * 2 - 1;
                mouseY = -(event.touches[0].clientY / window.innerHeight) * 2 + 1;
            }
        }

        // --- Animation Loop ---
        function animate() {
            animationHandle = requestAnimationFrame(animate);

            if (isPaused || !particleSystem) {
                if (isPaused) {
                    cancelAnimationFrame(animationHandle);
                    animationHandle = null;
                }
                return;
            }

            const time = Date.now() * 0.001;

            if (Date.now() > uploadAbsorbUntil) {
                uploadAbsorbTarget = 0;
            }
            uploadAbsorb += (uploadAbsorbTarget - uploadAbsorb) * 0.09;

            // Project mouse coordinates into 3D space for spatial awareness
            const vector = new THREE.Vector3(mouseX, mouseY, 0.5);
            vector.unproject(camera);
            const dir = vector.sub(camera.position).normalize();
            const distance = -camera.position.z / dir.z;
            const mouse3D = camera.position.clone().add(dir.multiplyScalar(distance));
            
            // Convert to particle system's local space
            const localMouse = mouse3D.clone();
            particleSystem.worldToLocal(localMouse);

            // Track last pointer position for the explosion origin
            if (pointerDown) {
                lastPointerPos.copy(localMouse);
            }

            // Interaction State Machine & Haptics
            if (pointerDown) {
                let holdTime = Date.now() - interactionStart;
                if (holdTime < 2500) {
                    interactionState = 'fear';
                    transitionProgress = 0;
                    // Haptics: Erratic fear vibration
                    if (navigator.vibrate && Date.now() - lastVibrateTime > 150) {
                        navigator.vibrate([10, 20]);
                        lastVibrateTime = Date.now();
                    }
                } else {
                    interactionState = 'gather';
                    transitionProgress = Math.min(1.0, (holdTime - 2500) / 2000);
                    // Haptics: Deep, heavy, building pulse for the singularity
                    if (navigator.vibrate && Date.now() - lastVibrateTime > 300 - (transitionProgress * 150)) {
                        navigator.vibrate([50 + (transitionProgress * 50)]);
                        lastVibrateTime = Date.now();
                    }
                }
            } else if (interactionState !== 'bigbang') {
                interactionState = 'idle';
                transitionProgress = Math.max(0, transitionProgress - 0.05);
            }

            // Smoothly transition the entity's color based on its elemental state
            particleSystem.material.color.lerp(targetColor, 0.03);

            // Adjust opacity for the translucent glass/liquid effect
            const targetOpacity = (currentElement === 'liquid') ? 0.25 : 0.8;
            particleSystem.material.opacity += (targetOpacity - particleSystem.material.opacity) * 0.05;

            // Organic Breathing - Entire entity pulses
            const breath = 1.0 + Math.sin(time * 2) * 0.03 - uploadAbsorb * 0.12;
            particleSystem.scale.set(breath, breath, breath);

            // 1. Morphing & Awareness Logic
            const positions = particleSystem.geometry.attributes.position.array;
            let needsUpdate = false;

            for (let i = 0; i < PARTICLE_COUNT; i++) {
                const i3 = i * 3;
                
                let tx = targetPositions[i3];
                let ty = targetPositions[i3 + 1];
                let tz = targetPositions[i3 + 2];

                // Base Organic Restlessness
                let dx_rest = Math.sin(time * 3.0 + i) * 0.1;
                let dy_rest = Math.cos(time * 2.5 + i) * 0.1;
                let dz_rest = Math.sin(time * 2.0 + i) * 0.1;

                // Apply Elemental Physics Behaviors
                if (currentElement === 'water') {
                    // Wavy, flowing offsets
                    dy_rest += Math.sin(targetPositions[i3] * 2.0 + time * 4.0) * 0.4;
                    dz_rest += Math.cos(targetPositions[i3+1] * 2.0 + time * 4.0) * 0.4;
                    dx_rest *= 0.3; dz_rest *= 0.3; // Make it smoother
                } else if (currentElement === 'liquid') {
                    // Translucent orb behavior: radial surface tension and inner wobble
                    const dist = Math.sqrt(tx*tx + ty*ty + tz*tz) || 1;
                    const wave = Math.sin(dist * 2.0 - time * 3.0) * 0.25;
                    dx_rest += (tx / dist) * wave + Math.sin(time * 1.5 + ty * 0.5) * 0.15;
                    dy_rest += (ty / dist) * wave + Math.cos(time * 1.5 + tz * 0.5) * 0.15;
                    dz_rest += (tz / dist) * wave + Math.sin(time * 1.5 + tx * 0.5) * 0.15;
                } else if (currentElement === 'fire') {
                    // Flickering, licking flames pushing upward
                    dy_rest += Math.random() * 1.5; 
                    dx_rest += (Math.random() - 0.5) * 0.6;
                    dz_rest += (Math.random() - 0.5) * 0.6;
                } else if (currentElement === 'rock') {
                    // Rigid, heavy, almost no movement
                    dx_rest *= 0.02; dy_rest *= 0.02; dz_rest *= 0.02; 
                } else if (currentElement === 'smoke') {
                    // Diffuse expansion and slow upward drift
                    dx_rest += Math.sin(time * 0.5 + i) * 2.0;
                    dy_rest += Math.cos(time * 0.3 + i) * 2.0 + 1.0; 
                    dz_rest += Math.sin(time * 0.4 + i) * 2.0;
                }

                tx += dx_rest;
                ty += dy_rest;
                tz += dz_rest;

                if (uploadAbsorb > 0.001) {
                    const radial = Math.sqrt(tx * tx + ty * ty + tz * tz) || 0.001;
                    const swirlAngle = time * (10 + uploadAbsorb * 14) + radial * 1.4 + (i % 113) * 0.071;
                    const inward = uploadAbsorb * 3.4;
                    tx += (-tx / radial) * inward + Math.cos(swirlAngle) * radial * 0.07 * uploadAbsorb;
                    ty += (-ty / radial) * inward + Math.sin(swirlAngle) * radial * 0.07 * uploadAbsorb;
                    tz += (-tz / radial) * inward * 0.7 + Math.sin(swirlAngle * 0.6) * 0.2 * uploadAbsorb;
                }

                // Reactive Flinching, Singularity Collapse & Big Bang
                const dx = positions[i3] - localMouse.x;
                const dy = positions[i3 + 1] - localMouse.y;
                const dz = positions[i3 + 2] - localMouse.z;
                const distSq = dx*dx + dy*dy + dz*dz;
                const dist = Math.sqrt(distSq) || 0.001;
                
                if (interactionState === 'fear') {
                    if (distSq < 20.0) { // Large fear radius
                        const force = (20.0 - distSq) / 20.0;
                        // Erratic scattering with noise
                        tx += (dx/dist) * force * 4.0 + (Math.random()-0.5)*2.5;
                        ty += (dy/dist) * force * 4.0 + (Math.random()-0.5)*2.5;
                        tz += (dz/dist) * force * 4.0 + (Math.random()-0.5)*2.5;
                    }
                } else if (interactionState === 'gather' || (transitionProgress > 0 && interactionState !== 'bigbang')) {
                    // Phase 2: The Singularity. Collapse everything into an infinitely dense point.
                    const pull = transitionProgress;
                    
                    // Override base targets to pull all particles to the exact cursor position
                    tx = tx * (1 - pull) + localMouse.x * pull;
                    ty = ty * (1 - pull) + localMouse.y * pull;
                    tz = tz * (1 - pull) + localMouse.z * pull;
                    
                    // Add an intense, high-energy micro-vibration at the core
                    tx += (Math.random() - 0.5) * pull * 0.4;
                    ty += (Math.random() - 0.5) * pull * 0.4;
                    tz += (Math.random() - 0.5) * pull * 0.4;

                } else if (interactionState === 'bigbang') {
                    // Phase 3: The Big Bang. Massive outward expansion from the last touch point.
                    const dx_bb = positions[i3] - lastPointerPos.x;
                    const dy_bb = positions[i3 + 1] - lastPointerPos.y;
                    const dz_bb = positions[i3 + 2] - lastPointerPos.z;
                    const dist_bb = Math.sqrt(dx_bb*dx_bb + dy_bb*dy_bb + dz_bb*dz_bb) || 0.01;
                    
                    // Explosive outward push
                    tx += (dx_bb / dist_bb) * explosionForce;
                    ty += (dy_bb / dist_bb) * explosionForce;
                    tz += (dz_bb / dist_bb) * explosionForce;
                    
                    // Add chaotic starburst streaks
                    tx += (Math.random() - 0.5) * explosionForce * 0.6;
                    ty += (Math.random() - 0.5) * explosionForce * 0.6;
                    tz += (Math.random() - 0.5) * explosionForce * 0.6;
                } else {
                    // Idle default flinch
                    if (distSq < 6.0) {
                        const force = (6.0 - distSq) / 6.0; 
                        tx += dx * force * 1.5;
                        ty += dy * force * 1.5;
                        tz += dz * force * 1.5;
                    }
                }

                // Interpolate current positions towards the modified targets
                const curX = positions[i3];
                const curY = positions[i3 + 1];
                const curZ = positions[i3 + 2];

                if (Math.abs(tx - curX) > 0.001 || Math.abs(ty - curY) > 0.001 || Math.abs(tz - curZ) > 0.001) {
                    positions[i3] += (tx - curX) * MORPH_SPEED;
                    positions[i3 + 1] += (ty - curY) * MORPH_SPEED;
                    positions[i3 + 2] += (tz - curZ) * MORPH_SPEED;
                    needsUpdate = true;
                }
            }

            if (needsUpdate) {
                particleSystem.geometry.attributes.position.needsUpdate = true;
            }

            // Decay the Big Bang explosion force
            if (interactionState === 'bigbang') {
                explosionForce *= 0.92; // Exponential decay
                if (explosionForce < 0.5) {
                    interactionState = 'idle';
                    transitionProgress = 0;
                }
            }

            // 2. Rotation Logic
            // Slowly rotate by default
            particleSystem.rotation.y += ROTATION_SPEED;
            particleSystem.rotation.x += ROTATION_SPEED * 0.5;

            // Decay touch reactivity back to normal over time
            touchReactivity += (1.0 - touchReactivity) * 0.05;

            // Add interactive tilt based on mouse position (Using double reactivity multiplier)
            targetRotationX = mouseY * touchReactivity;
            targetRotationY = mouseX * touchReactivity;
            
            particleSystem.rotation.x += (targetRotationX - particleSystem.rotation.x) * 0.05;
            particleSystem.rotation.y += (targetRotationY - particleSystem.rotation.y) * 0.05;

            renderer.render(scene, camera);
        }
    </script>

</body>
</html>
