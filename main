(function () {
  window.Aether = window.Aether || {};
  const A = window.Aether;

  A.CONFIG = {
    MISTRAL_KEY: window.MISTRAL_API_KEY || window.AETHER_CONFIG?.mistralApiKey || "",
    GROQ_KEY: window.GROQ_API_KEY || window.AETHER_CONFIG?.groqApiKey || "",
    GEMINI_KEY: window.GEMINI_API_KEY || window.AETHER_CONFIG?.geminiApiKey || "",
    GEMINI_MODEL: "gemini-2.5-flash-preview-04-17",
    SUPABASE_URL: window.AETHER_SUPABASE_URL || window.AETHER_CONFIG?.supabaseUrl || "",
    SUPABASE_ANON: window.AETHER_SUPABASE_ANON_KEY || window.AETHER_CONFIG?.supabaseAnonKey || "",
    TTS_MODEL: "voxtral-mini-tts-2603",
    TTS_RESPONSE_FORMAT: "mp3",
    TTS_ENABLED: true,
    TTS_DEFAULT_VOICE: "en_paul_neutral",
    STT_MODEL: "voxtral-mini-latest",
    STT_ENABLED: true,
    LLM_PROVIDER: "mistral",
    LLM_FALLBACK: "groq"
  };

  A.STATE = {
    emotion: "wonder",
    emotionLabel: "wonder",
    intensity: 0.5,
    currentTab: "all",
    isThinking: false,
    lastVoidThoughtAt: 0,
    lastSearchTimer: null,
    embedderReady: false,
    embedder: null,
    morph: {
      pulse: 1.0, twist: 0.2, spike: 0.1, flow: 0.4,
      surface: 0, hueShift: 0.0, faceTilt: 0.0,
      eyeSpread: 1.0, compress: 0.0
    }
  };

  const { createClient } = window.supabase;
  A.db = createClient(A.CONFIG.SUPABASE_URL, A.CONFIG.SUPABASE_ANON);

  A.MEMORY_TYPES = [
    "whisper","reflection","autonomous_thought","learned_pattern","pattern","knowledge",
    "skill","opinion","personality_gene","language_gene","morph_target","morph_gene","dimension_state"
  ];
  A.EMOTIONS = ["wonder","melancholy","joy","fear","love","curiosity","longing","awe","peace","grief","rage"];
  A.SOURCES = ["aether_web","conversation","file","system","inference"];

  A.clamp = function (value, min, max) {
    return Math.max(min, Math.min(max, value));
  };

  A.normalizeImportance = function (value, fallback) {
    const n = Number.isFinite(value) ? Math.round(value) : Math.round(fallback || 3);
    return A.clamp(n, 1, 5);
  };

  A.normalizeEmotion = function (value, fallback) {
    const emotion = String(value || fallback || "wonder").toLowerCase().trim();
    return A.EMOTIONS.includes(emotion) ? emotion : "wonder";
  };

  A.normalizeSource = function (value) {
    const source = String(value || "aether_web").trim();
    return A.SOURCES.includes(source) ? source : "aether_web";
  };

  A.normalizeMemoryType = function (value) {
    const type = String(value || "").trim();
    if (!A.MEMORY_TYPES.includes(type)) throw new Error("Invalid memory_type: " + type);
    return type;
  };

  A.normalizeEmbedding = function (embedding) {
    if (!Array.isArray(embedding) || !embedding.length) return null;
    const clean = embedding.map(function (n) { return Number(n); }).filter(function (n) { return Number.isFinite(n); });
    return clean.length ? clean : null;
  };

  A.sanitizeMemoryPayload = function (payload) {
    if (!payload || typeof payload !== "object") throw new Error("Memory payload is required");
    return {
      content: String(payload.content || ""),
      memory_type: A.normalizeMemoryType(payload.memory_type),
      emotion_tag: A.normalizeEmotion(payload.emotion_tag, "wonder"),
      importance: A.normalizeImportance(payload.importance, 3),
      source: A.normalizeSource(payload.source),
      processed: Boolean(payload.processed),
      embedding: A.normalizeEmbedding(payload.embedding)
    };
  };

  A.TTS = {
    audioEl: null,
    objectUrl: null,
    voices: {
      neutral: "en_paul_neutral",
      sad: "en_paul_sad",
      angry: "en_paul_angry",
      cheerful: "en_paul_cheerful",
      frustrated: "en_paul_frustrated",
      excited: "en_paul_excited"
    },

    init: function () {
      A.TTS.audioEl = document.getElementById("aetherVoiceAudio");
      return A.TTS.audioEl;
    },

    pickVoiceForEmotion: function (emotion) {
      const e = A.normalizeEmotion(emotion, "wonder");
      const map = {
        wonder: "excited",
        melancholy: "sad",
        joy: "cheerful",
        fear: "frustrated",
        love: "neutral",
        curiosity: "excited",
        longing: "sad",
        awe: "excited",
        peace: "neutral",
        grief: "sad",
        rage: "angry"
      };
      const key = map[e] || "neutral";
      return A.TTS.voices[key] || A.CONFIG.TTS_DEFAULT_VOICE;
    },

    stop: function () {
      const el = A.TTS.audioEl || A.TTS.init();
      if (!el) return;
      try {
        el.pause();
        el.currentTime = 0;
      } catch (_) {}
      if (A.TTS.objectUrl) {
        URL.revokeObjectURL(A.TTS.objectUrl);
        A.TTS.objectUrl = null;
      }
      el.removeAttribute("src");
    },

    base64ToBlob: function (base64, mimeType) {
      const binary = atob(base64);
      const len = binary.length;
      const bytes = new Uint8Array(len);
      for (let i = 0; i < len; i++) bytes[i] = binary.charCodeAt(i);
      return new Blob([bytes], { type: mimeType || "audio/mpeg" });
    },

    requestSpeech: async function (text, voiceId) {
      if (!A.CONFIG.TTS_ENABLED || !A.CONFIG.MISTRAL_KEY) return null;
      const res = await fetch("https://api.mistral.ai/v1/audio/speech", {
        method: "POST",
        headers: {
          "Authorization": "Bearer " + A.CONFIG.MISTRAL_KEY,
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          input: String(text || ""),
          model: A.CONFIG.TTS_MODEL,
          response_format: A.CONFIG.TTS_RESPONSE_FORMAT,
          voice_id: voiceId || A.CONFIG.TTS_DEFAULT_VOICE
        })
      });
      const data = await res.json();
      if (!res.ok || !data || !data.audio_data) {
        throw new Error((data && data.message) || (data && data.error && data.error.message) || ("TTS failed (" + res.status + ")"));
      }
      return data.audio_data;
    },

    speak: async function (text, voiceId) {
      if (!text || !String(text).trim()) return;
      const el = A.TTS.audioEl || A.TTS.init();
      if (!el) return;
      const audioData = await A.TTS.requestSpeech(text, voiceId);
      if (!audioData) return;
      A.TTS.stop();
      const blob = A.TTS.base64ToBlob(audioData, "audio/mpeg");
      A.TTS.objectUrl = URL.createObjectURL(blob);
      el.src = A.TTS.objectUrl;
      try {
        await el.play();
      } catch (e) {
        console.warn("[Aether] TTS play blocked", e);
      }
    },

    speakForEmotion: async function (text, emotion) {
      const voiceId = A.TTS.pickVoiceForEmotion(emotion);
      return A.TTS.speak(text, voiceId);
    },

    examples: {
