  mistralApiKey: window.MISTRAL_API_KEY,
  groqApiKey: window.GROQ_API_KEY,
  geminiApiKey: window.GEMINI_API_KEY,
  supabaseUrl: window.AETHER_SUPABASE_URL,
  supabaseAnonKey: window.AETHER_SUPABASE_ANON_KEY,
